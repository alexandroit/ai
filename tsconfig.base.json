{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@stackline/ai": ["./packages/ai/src/index.ts"],
      "@stackline/ai/server": ["./packages/ai/src/index.ts"],
      "@stackline/ai-server": ["./packages/server/src/index.ts"],
      "@stackline/ai-ui": ["./packages/ui/src/index.ts"]
    },
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "declaration": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true
  }
}
