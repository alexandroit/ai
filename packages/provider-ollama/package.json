{
  "name": "@stackline/ai-ollama",
  "version": "0.0.1",
  "description": "Ollama provider adapter for Stackline AI.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --sourcemap --clean --external @stackline/ai && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "pack:dry-run": "pnpm pack --dry-run"
  },
  "dependencies": {
    "@stackline/ai": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "stackline",
    "stackline-ai",
    "ai",
    "artificial-intelligence",
    "generative-ai",
    "ollama",
    "ollama-ai",
    "ollama-api",
    "ollama-provider",
    "local-ollama",
    "local-llm",
    "llm",
    "llm-provider",
    "provider",
    "provider-adapter",
    "model-listing",
    "auto-model",
    "chat",
    "chatbot",
    "backend",
    "gateway",
    "rag-ready",
    "typescript",
    "javascript"
  ]
}
