{
  "name": "@stackline/ai-rag-postgres",
  "version": "0.0.1",
  "description": "PostgreSQL read-only RAG retriever for Stackline AI.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --sourcemap --clean --external @stackline/ai && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "pack:dry-run": "pnpm pack --dry-run"
  },
  "dependencies": {
    "@stackline/ai": "workspace:*",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/pg": "^8.16.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "stackline",
    "stackline-ai",
    "ai",
    "artificial-intelligence",
    "generative-ai",
    "rag",
    "retrieval-augmented-generation",
    "context-retrieval",
    "retriever",
    "database-retriever",
    "postgres",
    "postgresql",
    "pg",
    "database",
    "sql",
    "readonly-sql",
    "readonly",
    "llm",
    "backend",
    "knowledge-base",
    "typescript",
    "javascript"
  ]
}
